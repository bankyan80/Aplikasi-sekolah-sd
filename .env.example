# Database Connection (Supabase PostgreSQL)
# Replace [YOUR-PASSWORD] with your actual database password

# Connection pooling (untuk aplikasi) - port 6543
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.lryrzhkthqvqngvdopuy.supabase.co:6543/postgres?pgbouncer=true"

# Direct connection (untuk migration) - port 5432
DIRECT_DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.lryrzhkthqvqngvdopuy.supabase.co:5432/postgres"

# Notes:
# - DATABASE_URL uses port 6543 for connection pooling (pgbouncer)
# - DIRECT_DATABASE_URL uses port 5432 for direct connections (migrations)
# - Replace [YOUR-PASSWORD] with the password you saved when creating the database
